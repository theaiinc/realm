{
  "name": "@theaiinc/realm-browser",
  "version": "0.1.0",
  "description": "Playwright/Chromium browser engine for Realm — enables AI agents to interact with web pages through a headless browser",
  "keywords": ["realm", "browser", "playwright", "chromium", "web-automation", "ai-agent"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@theaiinc/realm-core": "workspace:*",
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theaiinc/realm.git",
    "directory": "packages/realm-browser"
  }
}
