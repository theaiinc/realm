{
  "name": "@theaiinc/realm-container",
  "version": "0.1.1",
  "description": "Docker-based container engine for Realm — provides isolated Linux sandboxes with filesystem, network, and lifecycle management",
  "keywords": ["realm", "docker", "container", "sandbox", "ai-agent", "execution-environment"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@theaiinc/realm-core": "workspace:*",
    "dockerode": "^4.0.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theaiinc/realm.git",
    "directory": "packages/realm-container"
  },
  "homepage": "https://github.com/theaiinc/realm/blob/main/packages/realm-container/README.md",
  "bugs": {
    "url": "https://github.com/theaiinc/realm/issues"
  }
}
