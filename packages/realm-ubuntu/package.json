{
  "name": "@theaiinc/realm-ubuntu",
  "version": "0.1.2",
  "description": "Ubuntu Desktop engine for Realm — provides a full XFCE4 desktop environment in Docker with VNC, Chromium, and embedded Yggdrasil Ratatoskr for AI agent computer-use tasks",
  "keywords": ["realm", "ubuntu", "desktop", "docker", "xfce", "vnc", "ratatoskr", "yggdrasil", "ai-agent", "computer-use"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "build:docker": "docker build -t realm-ubuntu -f assets/Dockerfile .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@theaiinc/realm-core": "workspace:*",
    "@theaiinc/yggdrasil-ratatoskr": "^0.3.0",
    "dockerode": "^4.0.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theaiinc/realm.git",
    "directory": "packages/realm-ubuntu"
  },
  "homepage": "https://github.com/theaiinc/realm/blob/main/packages/realm-ubuntu/README.md",
  "bugs": {
    "url": "https://github.com/theaiinc/realm/issues"
  }
}
