{
  "name": "@theaiinc/realm-veil",
  "version": "0.1.0",
  "description": "Veil PII redaction integration for Realm — automatically detects and redacts sensitive data in agent outputs",
  "keywords": ["realm", "veil", "pii", "redaction", "privacy", "security", "ai-agent"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@theaiinc/realm-core": "workspace:*",
    "@theaiinc/veil": "^0.1.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theaiinc/realm.git",
    "directory": "packages/realm-veil"
  }
}
