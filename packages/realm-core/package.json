{
  "name": "@theaiinc/realm-core",
  "version": "0.1.0",
  "description": "Core abstractions, types, and API facade for the Realm platform — the universal interface for isolated AI execution environments",
  "keywords": ["realm", "ai", "agent", "sandbox", "isolation", "execution-environment"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theaiinc/realm.git",
    "directory": "packages/realm-core"
  }
}
